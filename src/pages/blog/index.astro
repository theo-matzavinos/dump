---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getVisibleBlogPosts } from '../../utils/blog';

const posts = getVisibleBlogPosts(await getCollection('blog'));
---

<SiteLayout title={`${SITE_TITLE} Archive`} description={SITE_DESCRIPTION}>
	<section class="page-intro">
		<p class="eyebrow">Archive</p>
		<h1>Articles</h1>
		<p>The archive currently contains a single long-form article on dependency injection in Angular.</p>
	</section>

	<div class="archive-list">
		{
			posts.map((post) => (
				<article class="archive-item">
					<div class="archive-item__meta">
						<p>
							<FormattedDate date={post.data.pubDate} />
						</p>
						{post.data.tags.length > 0 && <ul class="tag-list">{post.data.tags.map((tag) => <li>{tag}</li>)}</ul>}
					</div>
					<div>
						<h2>
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						</h2>
						<p>{post.data.description}</p>
					</div>
				</article>
			))
		}
	</div>
</SiteLayout>
